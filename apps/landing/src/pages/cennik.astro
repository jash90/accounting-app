---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import { pricingTiers } from '@/lib/content/pricing';
import { faqItems } from '@/lib/content/faq';
import { APP_URL } from '@/lib/content/navigation';
---

<BaseLayout title="Cennik - AppTax" description="Plany cenowe AppTax — Starter, Professional i Enterprise. Wybierz odpowiedni plan dla swojego biura rachunkowego.">
  <Header />
  <main>
    <section class="py-20 lg:py-28">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-2xl text-center">
          <h1 class="text-3xl font-bold tracking-tight sm:text-4xl lg:text-5xl">
            Wybierz plan dla swojego biura
          </h1>
          <p class="mt-4 text-lg text-muted-foreground">
            Zacznij od 14-dniowego okresu próbnego. Bez karty kredytowej.
          </p>
        </div>

        <div class="mx-auto mt-16 grid max-w-5xl grid-cols-1 gap-8 lg:grid-cols-3">
          {pricingTiers.map((tier) => (
            <div
              class:list={[
                'relative flex flex-col rounded-2xl border p-8',
                tier.highlighted
                  ? 'border-primary ring-2 ring-primary scale-[1.02]'
                  : 'border-border',
              ]}
            >
              {tier.highlighted && (
                <div class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-primary px-4 py-1 text-xs font-medium text-primary-foreground">
                  Najpopularniejszy
                </div>
              )}
              <h3 class="text-xl font-bold">{tier.name}</h3>
              <p class="mt-1 text-sm text-muted-foreground">{tier.description}</p>
              <div class="mt-6">
                {tier.price === 'Indywidualny' ? (
                  <span class="text-3xl font-bold">{tier.price}</span>
                ) : (
                  <>
                    <span class="text-4xl font-bold">{tier.price}</span>
                    <span class="text-lg text-muted-foreground"> zł{tier.period}</span>
                  </>
                )}
              </div>
              <ul class="mt-8 flex-1 space-y-3">
                {tier.features.map((feature) => (
                  <li class="flex items-start gap-2">
                    <span class="mt-0.5 text-green-500">✓</span>
                    <span class="text-sm">{feature}</span>
                  </li>
                ))}
              </ul>
              <a
                href={APP_URL}
                class:list={[
                  'mt-8 inline-flex items-center justify-center rounded-md px-6 py-3 text-sm font-medium transition-colors',
                  tier.highlighted
                    ? 'bg-primary text-primary-foreground hover:bg-primary/90'
                    : 'border border-border hover:bg-accent',
                ]}
              >
                {tier.cta}
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="faq" class="border-t border-border bg-muted/30 py-20 lg:py-28">
      <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-center text-3xl font-bold tracking-tight sm:text-4xl">
          Często zadawane pytania
        </h2>
        <div class="mt-12 space-y-0 divide-y divide-border">
          {faqItems.map((item) => (
            <details class="group py-5">
              <summary class="flex cursor-pointer items-center justify-between font-medium">
                {item.question}
                <span class="ml-4 text-muted-foreground transition-transform group-open:rotate-180">
                  ▾
                </span>
              </summary>
              <p class="mt-3 text-muted-foreground">{item.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
