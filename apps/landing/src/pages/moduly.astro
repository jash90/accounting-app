---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import { modules } from '@/lib/content/modules';
import { APP_URL } from '@/lib/content/navigation';

const iconColors = [
  'bg-blue-500', 'bg-green-500', 'bg-purple-500', 'bg-orange-500', 'bg-red-500',
  'bg-cyan-500', 'bg-yellow-500', 'bg-teal-500', 'bg-pink-500',
];
---

<BaseLayout title="Moduły - AppTax" description="Poznaj 9 modułów AppTax: zadania, śledzenie czasu, klienci, rozliczenia, oferty, email, dokumenty, asystent AI i powiadomienia.">
  <Header />
  <main>
    <section class="py-20 text-center lg:py-28">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <h1 class="text-3xl font-bold tracking-tight sm:text-4xl lg:text-5xl">Wszystkie moduły</h1>
        <p class="mx-auto mt-4 max-w-2xl text-lg text-muted-foreground">
          Poznaj pełen zestaw narzędzi zaprojektowanych dla Twojego biura rachunkowego
        </p>
      </div>
    </section>

    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      {modules.map((mod, i) => (
        <section id={mod.id} class:list={['py-16', i < modules.length - 1 && 'border-b border-border']}>
          <div class:list={['flex flex-col items-center gap-12 lg:flex-row', i % 2 !== 0 && 'lg:flex-row-reverse']}>
            <div class="flex w-full items-center justify-center lg:w-1/2">
              <div class={`flex aspect-video w-full max-w-md items-center justify-center rounded-2xl ${iconColors[i]}/10`}>
                <span class={`text-6xl font-bold ${iconColors[i].replace('bg-', 'text-')}`}>
                  {mod.name.charAt(0)}
                </span>
              </div>
            </div>
            <div class="w-full lg:w-1/2">
              <h2 class="text-2xl font-bold sm:text-3xl">{mod.name}</h2>
              <p class="mt-3 text-muted-foreground">{mod.description}</p>
              <div class="mt-6 grid grid-cols-1 gap-2 sm:grid-cols-2">
                {mod.features.map((feature) => (
                  <div class="flex items-start gap-2">
                    <span class="mt-0.5 text-green-500">✓</span>
                    <span class="text-sm">{feature}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </section>
      ))}
    </div>

    <section class="bg-apptax-gradient py-20 text-center text-white">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">Wszystkie moduły w jednej platformie</h2>
        <p class="mx-auto mt-4 max-w-xl text-lg text-white/70">
          Zacznij korzystać ze wszystkich narzędzi już dziś.
        </p>
        <a
          href={APP_URL}
          class="mt-10 inline-flex items-center justify-center rounded-md bg-white px-8 py-3.5 text-sm font-semibold text-apptax-navy transition-colors hover:bg-white/90"
        >
          Wypróbuj za darmo
        </a>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
