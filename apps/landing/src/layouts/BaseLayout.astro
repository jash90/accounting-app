---
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'AppTax to nowoczesna platforma AI do zarządzania biurem rachunkowym. Zadania, klienci, rozliczenia, dokumenty, śledzenie czasu i asystent AI.',
} = Astro.props;

import '@/styles/global.css';
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#1E3A5F" />
    <link rel="icon" type="image/svg+xml" href="/apptax-favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="pl_PL" />
    <meta property="og:site_name" content="AppTax" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <script is:inline>
      const t = localStorage.getItem('theme');
      if (t === 'dark' || (!t && matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      }
    </script>
  </head>
  <body class="min-h-screen bg-background text-foreground font-sans antialiased">
    <slot />
  </body>
</html>
